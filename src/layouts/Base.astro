---
const { title = "Portfolio", description = "" } = Astro.props;
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" href="/favicon.ico" />

    <!-- Global theme -->
    <link rel="stylesheet" href="/theme.css" />
    <link rel="stylesheet" href="/ui.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="wrap">
        <a class="brand" href="/">dijkman.dev</a>
        <nav class="nav">
          <a href="/cv">CV</a>
          <a href="/homelab">Homelab</a>
          <a href="/services">Services</a>
          <a href="/tech">Tech</a>
          <a href="/arcade">Arcade</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="wrap footer">
      <span class="muted">© {new Date().getFullYear()} Thijs Dijkman</span>
    </footer>

    <script is:inline>
      window.$sitegpt = window.$sitegpt || [];
      (function () {
        const d = document;
        const s = d.createElement("script");
        s.src = "https://sitegpt.ai/widget/0387ad53-c5cf-4ddc-8446-692aadcac1f5.js";
        s.async = true;
        (d.head || d.getElementsByTagName("head")[0]).appendChild(s);
      })();
    </script>

  </body>
</html>
